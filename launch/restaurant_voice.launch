<?xml version="1.0"?>
<launch>

  <!-- ──────────────────────────────────────────────────────────────────
       Restaurant Ordering Voice Pipeline

       Launches two nodes:
         1. voice_listener    – microphone → hotword → STT → transcript
         2. order_processor   – transcript → dialogue → order JSON

       Both nodes communicate via ROS topics/services (std_msgs/String
       JSON payloads + std_srvs/Trigger).

       Usage:
         roslaunch restaurant_language_unit restaurant_voice.launch
         roslaunch restaurant_language_unit restaurant_voice.launch stt_model:=small
         roslaunch restaurant_language_unit restaurant_voice.launch wake_words:="hey waiter,order"
       ─────────────────────────────────────────────────────────────────── -->

  <!-- ═══════════════════════════════════════════════════════════════════
       Arguments
       ═══════════════════════════════════════════════════════════════════ -->

  <arg name="wake_words"    default="hey tiago, excuse me, order please"/>
  <arg name="stt_model"     default="base"/>
  <arg name="language"      default="en"/>
  <arg name="device"        default="cpu"/>
  <arg name="compute_type"  default="int8"/>
  <arg name="silence_dur"   default="0.8"/>
  <arg name="confirm_delay" default="2.0"/>
  <arg name="sample_rate"   default="16000"/>
  <arg name="pre_buffer"    default="0.4"/>
  <arg name="max_utterance" default="10.0"/>
  <arg name="interrupt_mult" default="6.0"/>
  <arg name="tts_rate"      default="175"/>
  <arg name="tts_volume"    default="1.0"/>
  <arg name="enable_calib"  default="true"/>
  <arg name="calib_interval" default="60.0"/>
  <arg name="table_id"      default="default"/>

  <!-- ═══════════════════════════════════════════════════════════════════
       Voice Listener Node  –  always-on microphone → transcripts
       ═══════════════════════════════════════════════════════════════════ -->

  <node name="voice_listener" pkg="restaurant_language_unit"
        type="voice_listener_node.py" output="screen">

    <!-- Wake words (YAML list or comma-separated string) -->
    <param name="wake_words"    value="$(arg wake_words)"/>

    <!-- faster-whisper model -->
    <param name="stt_model"     value="$(arg stt_model)"/>
    <param name="language"      value="$(arg language)"/>
    <param name="device"        value="$(arg device)"/>
    <param name="compute_type"  value="$(arg compute_type)"/>

    <!-- VAD / silence detection -->
    <param name="silence_dur"   value="$(arg silence_dur)"/>
    <param name="confirm_delay" value="$(arg confirm_delay)"/>
    <param name="sample_rate"   value="$(arg sample_rate)"/>
    <param name="pre_buffer_seconds" value="$(arg pre_buffer)"/>
    <param name="max_utterance_seconds" value="$(arg max_utterance)"/>

    <!-- Barge-in / interruption -->
    <param name="interrupt_multiplier" value="$(arg interrupt_mult)"/>

    <!-- TTS (pyttsx3, optional) -->
    <param name="tts_rate"      value="$(arg tts_rate)"/>
    <param name="tts_volume"    value="$(arg tts_volume)"/>

    <!-- Ambient calibration -->
    <param name="enable_ambient_calibration"       value="$(arg enable_calib)"/>
    <param name="ambient_calibration_interval"     value="$(arg calib_interval)"/>
  </node>

  <!-- ═══════════════════════════════════════════════════════════════════
       Order Processor Node  –  dialogue + order parsing
       ═══════════════════════════════════════════════════════════════════ -->

  <node name="order_processor" pkg="restaurant_language_unit"
        type="order_processor_node.py" output="screen">

    <param name="table_id" value="$(arg table_id)"/>

    <!-- Menu data loaded from the package's menu.json by default.
         Override by pointing ~menu to a YAML or JSON list. -->
    <rosparam command="load"
              file="$(find restaurant_language_unit)/menu.json"
              ns="order_processor/menu"/>
  </node>

</launch>
